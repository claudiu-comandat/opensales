# OpenSales — environment variables (copy to .env for local dev only)
#
# WARNING: do NOT copy these defaults into a hosted deployment (Railway,
# Fly.io, Render, etc.). The values below are LOCAL-DEV-ONLY. In hosted
# environments:
#   - DATABASE_URL is provided by your Postgres plugin (Railway: ${{Postgres.DATABASE_URL}})
#   - SESSION_SECRET and PLATFORM_MASTER_KEY are AUTO-GENERATED on first
#     boot by scripts/entrypoint.sh and persisted in /app/data/secrets
#     (mounted as a volume). Leave them UNSET in your hosting platform.
#   - WEB_URL points to the frontend service public URL
#     (Railway: https://${{web.RAILWAY_PUBLIC_DOMAIN}})

# ---- Runtime ----
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ---- Database (Postgres 16+) ----
# Local dev with `pnpm db:up`:
DATABASE_URL=postgres://opensales:opensales@localhost:5432/opensales

# ---- Auth & Session ----
# DO NOT SET IN PROD — entrypoint auto-generates and persists to volume.
# Local-dev only: 64 hex chars (= 32 bytes). Generate with: openssl rand -hex 32
# SESSION_SECRET=
SESSION_TTL_HOURS=168

# ---- Plugin secret storage ----
# DO NOT SET IN PROD — entrypoint auto-generates and persists to volume.
# Local-dev only: 64 hex chars. Generate with: openssl rand -hex 32
# PLATFORM_MASTER_KEY=

# ---- Plugin engine ----
PLATFORM_VERSION=0.1.0
PLUGINS_ROOT=./plugins

# ---- Frontend (apps/web origin used by API CORS) ----
# Railway: WEB_URL=https://${{web.RAILWAY_PUBLIC_DOMAIN}}
WEB_URL=http://localhost:3000

# ---- Initial admin (seeded on first migrate; both vars required, password >= 12 chars) ----
INITIAL_ADMIN_EMAIL=admin@opensales.local
INITIAL_ADMIN_PASSWORD=ChangeMeNow2026

# ---- Frontend (Next.js apps/web) ----
# Railway: NEXT_PUBLIC_API_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}
NEXT_PUBLIC_API_URL=http://localhost:3001