# Dependencies
node_modules/

# Build outputs
dist/
.next/
.turbo/
*.tsbuildinfo
*.js.map
*.d.ts.map

# tsc -b emits next to source for `composite` packages — ignore the artifacts
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
apps/*/src/**/*.js
apps/*/src/**/*.d.ts

# Env files (keep .env.example)
.env*
!.env.example

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# Coverage
coverage/

# Plugin data and build output
plugins/*/data/*
!plugins/*/data/.gitkeep
plugins/*/dist
.claude-context/
