{
  "name": "@opensales/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch --env-file=../../.env src/main.ts",
    "start": "SWC_NODE_PROJECT=tsconfig.json node --import @swc-node/register/esm-register src/main.ts",
    "start:prod": "tsx ../../packages/db/src/migrate.ts && SWC_NODE_PROJECT=tsconfig.json node --import @swc-node/register/esm-register src/main.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.6",
    "@nestjs/core": "^10.4.6",
    "@nestjs/platform-express": "^10.4.6",
    "@nestjs/swagger": "^8.0.0",
    "@opensales/db": "workspace:^",
    "@opensales/plugin-sdk": "workspace:^",
    "@swc-node/register": "^1.10.10",
    "argon2": "^0.41.1",
    "cookie": "^1.0.1",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.36.1",
    "nestjs-pino": "^4.1.0",
    "nestjs-zod": "^4.3.0",
    "pg-boss": "^10.1.5",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.2",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "zod-openapi": "^4.1.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.28",
    "@swc/core": "^1.15.46",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.2.0",
    "@types/supertest": "^7.2.1",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0",
    "tsx": "^4.23.1",
    "unplugin-swc": "^1.5.1"
  }
}
