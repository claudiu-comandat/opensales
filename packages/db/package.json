{
  "name": "@opensales/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./nest": "./src/nest/db.module.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file-if-exists=../../.env src/migrate.ts",
    "db:seed:admin": "tsx --env-file-if-exists=../../.env src/seed/admin.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.36.1",
    "postgres": "^3.4.5",
    "uuid": "^11.0.2"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "@nestjs/common": "^10",
    "@nestjs/core": "^10"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    }
  }
}
